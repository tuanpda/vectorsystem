# Copy: cp deploy/env.production.example api/.env
# Đổi mật khẩu, JWT, domain CORS trước khi chạy production.

NODE_ENV=production
API_PORT=3000
API_HOST=127.0.0.1

# Domain public (HTTPS) — Admin cùng origin qua Nginx thì có thể bỏ trống
CORS_ORIGINS=https://vectorsystem.io.vn,https://www.vectorsystem.io.vn

DATABASE_URL=postgresql://mk:CHANGE_DB_PASSWORD@127.0.0.1:5433/knowledge?schema=public
REDIS_URL=redis://127.0.0.1:6380

MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=mkminio
MINIO_SECRET_KEY=CHANGE_MINIO_SECRET
MINIO_BUCKET=knowledge

MINERU_API_URL=http://127.0.0.1:8000
MINERU_POLL_INTERVAL_MS=2000
MINERU_TASK_TIMEOUT_MS=3600000
PARSE_QUEUE_CONCURRENCY=1

JWT_SECRET=CHANGE_TO_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=admin@vectorsystem.io.vn
ADMIN_PASSWORD=CHANGE_STRONG_PASSWORD
ADMIN_DISPLAY_NAME=Administrator

EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHUNK_MAX_CHARS=4000
CHUNK_OVERLAP_CHARS=200
EMBEDDING_BATCH_SIZE=32

// Knowledge Platform — schema v1 (Phase 0)
// pgvector extension: bật ở migration SQL; bảng embedding thêm ở Phase 2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentStatus {
  uploaded
  queued_parse
  parsing
  parsed
  queued_index
  indexing
  indexed
  failed
}

enum ParseJobStatus {
  pending
  processing
  completed
  failed
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  displayName  String?    @map("display_name")
  role         String     @default("admin")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  documents    Document[]
  apiKeys      ApiKey[]

  @@map("users")
}

model Document {
  id              String         @id @default(uuid())
  tenantId        String         @default("default") @map("tenant_id")
  ownerId         String?        @map("owner_id")
  owner           User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  title           String
  originalName    String         @map("original_name")
  mimeType        String         @map("mime_type")
  fileSize        Int            @map("file_size")
  storageKey      String         @map("storage_key")
  status          DocumentStatus @default(uploaded)
  tags            String[]       @default([])
  language        String         @default("vi")
  mineruBackend   String         @default("pipeline") @map("mineru_backend")
  chunkCount      Int            @default(0) @map("chunk_count")
  indexPromptTokens Int?         @map("index_prompt_tokens")
  indexEstimatedUsd Decimal?       @map("index_estimated_usd") @db.Decimal(12, 6)
  errorMessage    String?        @map("error_message")
  indexedAt       DateTime?      @map("indexed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  parseJobs       ParseJob[]
  parsedArtifact  ParsedArtifact?
  chunks          Chunk[]
  openAiUsageLogs OpenAiUsageLog[]

  @@index([tenantId, status])
  @@index([createdAt])
  @@map("documents")
}

model ParseJob {
  id            String         @id @default(uuid())
  documentId    String         @map("document_id")
  document      Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  mineruTaskId  String?        @map("mineru_task_id")
  status        ParseJobStatus @default(pending)
  backend       String         @default("pipeline")
  errorMessage  String?        @map("error_message")
  startedAt     DateTime?      @map("started_at")
  completedAt   DateTime?      @map("completed_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  @@index([documentId])
  @@map("parse_jobs")
}

model ParsedArtifact {
  id                String   @id @default(uuid())
  documentId        String   @unique @map("document_id")
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  markdownKey       String?  @map("markdown_key")
  contentListKey    String?  @map("content_list_key")
  imagesPrefix      String?  @map("images_prefix")
  mineruVersion     String?  @map("mineru_version")
  pageCount         Int?     @map("page_count")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("parsed_artifacts")
}

model Chunk {
  id          String   @id @default(uuid())
  documentId  String   @map("document_id")
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex  Int      @map("chunk_index")
  blockType   String   @map("block_type")
  content     String   @db.Text
  tokenCount  Int?     @map("token_count")
  pageIdx     Int?     @map("page_idx")
  headingPath String?  @map("heading_path")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("chunks")
}

model OpenAiUsageLog {
  id           String    @id @default(uuid())
  tenantId     String    @default("default") @map("tenant_id")
  documentId   String?   @map("document_id")
  document     Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  operation    String
  model        String
  promptTokens Int       @map("prompt_tokens")
  totalTokens  Int       @map("total_tokens")
  estimatedUsd Decimal   @map("estimated_usd") @db.Decimal(12, 6)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([documentId])
  @@map("openai_usage_logs")
}

model ApiKey {
  id         String    @id @default(uuid())
  tenantId   String    @default("default") @map("tenant_id")
  name       String
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  scopes     String[]  @default(["rag:query"])
  createdBy  String?   @map("created_by")
  creator    User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("api_keys")
}

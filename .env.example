# === Knowledge Platform (NestJS) ===
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
# CORS_ORIGINS=https://knowledge.example.com

# PostgreSQL (docker-compose: port 5433)
DATABASE_URL=postgresql://mk:mk_secret@127.0.0.1:5433/knowledge?schema=public

# Redis (docker-compose: port 6380)
REDIS_URL=redis://127.0.0.1:6380

# MinIO (docker-compose)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=mkminio
MINIO_SECRET_KEY=mkminio_secret
MINIO_BUCKET=knowledge

# MinerU parse service (chạy riêng: .\run-mineru.ps1 api)
MINERU_API_URL=http://127.0.0.1:8000
MINERU_POLL_INTERVAL_MS=2000
MINERU_TASK_TIMEOUT_MS=3600000
PARSE_QUEUE_CONCURRENCY=1

# Auth (đổi secret khi deploy)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Admin (tự tạo user đầu tiên nếu DB chưa có user)
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=Administrator

# Embedding: openai (mac dinh) hoac ollama (local)
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Ollama (khi EMBEDDING_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768
CHUNK_MAX_CHARS=4000
CHUNK_OVERLAP_CHARS=200
EMBEDDING_BATCH_SIZE=32

# Chi phí OpenAI (tùy chọn)
# OPENAI_ADMIN_API_KEY=sk-admin-...   # Costs API — số tiền thật trên dashboard
# EMBEDDING_PRICE_PER_1M_USD=0.02     # Override giá / 1M token (mặc định theo model)
